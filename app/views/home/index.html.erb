<div data-theme="corporate">
  <!-- Hero Section with Navbar -->
  <div class="hero min-h-screen bg-base-200">
    <!-- Navbar -->
    <div class="navbar fixed top-0 z-50 bg-base-100 shadow-lg">
      <div class="navbar-start">
        <div class="dropdown">
          <label tabindex="0" class="btn btn-ghost lg:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" /></svg>
          </label>
          <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
            <li><a href="#features">Features</a></li>
            <li><a href="#solutions">Solutions</a></li>
            <li><a href="#pricing">Pricing</a></li>
            <li><a href="#about">About</a></li>
          </ul>
        </div>
        <a class="btn btn-ghost normal-case text-xl">
          <div class="avatar placeholder">
            <div class="bg-primary text-neutral-content rounded-lg w-10">
              <span class="text-xl">DF</span>
            </div>
          </div>
          <span class="ml-2 font-bold">DataFixPro</span>
        </a>
      </div>
      <div class="navbar-center hidden lg:flex">
        <ul class="menu menu-horizontal px-1">
          <li><a href="#features">Features</a></li>
          <li><a href="#solutions">Solutions</a></li>
          <li><a href="#pricing">Pricing</a></li>
          <li><a href="#about">About</a></li>
        </ul>
      </div>
      <div class="navbar-end">
        <% if user_signed_in? %>
          <%= link_to "Dashboard", dashboard_path, class: "btn btn-primary" %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "btn btn-ghost" %>
          <%= link_to "Get Started", new_user_registration_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>

    <!-- Hero Content -->
    <div class="hero-content text-center">
      <div class="max-w-5xl">
        <div class="badge badge-primary badge-lg mb-4">✨ Enterprise-Ready Data Platform</div>
        <h1 class="text-5xl md:text-7xl font-bold mb-6">
          Transform Your Data Into
          <span class="text-primary">Business Intelligence</span>
        </h1>
        <p class="text-xl md:text-2xl mb-8 text-base-content/80">
          Enterprise-grade ETL/ELT pipelines with visual workflow builder and AI-powered transformations.
          Connect, transform, and analyze your data at scale.
        </p>
        <div class="flex flex-col md:flex-row gap-4 justify-center">
          <%= link_to new_user_registration_path, class: "btn btn-primary btn-lg" do %>
            Start Free Trial
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          <% end %>
          <button class="btn btn-outline btn-lg">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.91 11.672a.375.375 0 010 .656l-5.603 3.113a.375.375 0 01-.557-.328V8.887c0-.286.307-.466.557-.327l5.603 3.112z" />
            </svg>
            Watch Demo
          </button>
        </div>

        <!-- Stats -->
        <div class="stats shadow mt-12 bg-base-100">
          <div class="stat">
            <div class="stat-figure text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12l7-7m-7 7l7 7"></path></svg>
            </div>
            <div class="stat-title">Data Processed</div>
            <div class="stat-value text-primary">25.6TB</div>
            <div class="stat-desc">21% more than last month</div>
          </div>

          <div class="stat">
            <div class="stat-figure text-secondary">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            </div>
            <div class="stat-title">Active Pipelines</div>
            <div class="stat-value text-secondary">2,450</div>
            <div class="stat-desc">Running 24/7</div>
          </div>

          <div class="stat">
            <div class="stat-figure text-accent">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6"></path></svg>
            </div>
            <div class="stat-value">99.9%</div>
            <div class="stat-title">Uptime</div>
            <div class="stat-desc">Enterprise SLA</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Features Section -->
  <section id="features" class="py-20 px-6 bg-base-100">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Powerful Features for Modern Data Teams</h2>
        <p class="text-xl text-base-content/70">Everything you need to build, deploy, and monitor data pipelines</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Feature Cards -->
        <div class="card bg-base-200 shadow-xl">
          <figure class="px-10 pt-10">
            <div class="rounded-xl bg-primary p-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-primary-content">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
              </svg>
            </div>
          </figure>
          <div class="card-body items-center text-center">
            <h2 class="card-title">Visual Pipeline Builder</h2>
            <p>Drag-and-drop interface to build complex data pipelines without writing code</p>
            <div class="card-actions">
              <button class="btn btn-primary btn-sm">Learn More</button>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 shadow-xl">
          <figure class="px-10 pt-10">
            <div class="rounded-xl bg-secondary p-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-secondary-content">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
              </svg>
            </div>
          </figure>
          <div class="card-body items-center text-center">
            <h2 class="card-title">Code-First Development</h2>
            <p>Full Python and SQL support for advanced transformations and custom logic</p>
            <div class="card-actions">
              <button class="btn btn-secondary btn-sm">Learn More</button>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 shadow-xl">
          <figure class="px-10 pt-10">
            <div class="rounded-xl bg-accent p-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-accent-content">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
              </svg>
            </div>
          </figure>
          <div class="card-body items-center text-center">
            <h2 class="card-title">AI-Powered Transformations</h2>
            <p>Intelligent data mapping and transformation suggestions powered by machine learning</p>
            <div class="card-actions">
              <button class="btn btn-accent btn-sm">Learn More</button>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 shadow-xl">
          <figure class="px-10 pt-10">
            <div class="rounded-xl bg-warning p-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-warning-content">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 14.25v2.25m3-4.5v4.5m3-6.75v6.75m3-9v9M6 20.25h12A2.25 2.25 0 0020.25 18V6A2.25 2.25 0 0018 3.75H6A2.25 2.25 0 003.75 6v12A2.25 2.25 0 006 20.25z" />
              </svg>
            </div>
          </figure>
          <div class="card-body items-center text-center">
            <h2 class="card-title">Real-Time Monitoring</h2>
            <p>Track pipeline performance, data quality, and system health in real-time</p>
            <div class="card-actions">
              <button class="btn btn-warning btn-sm">Learn More</button>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 shadow-xl">
          <figure class="px-10 pt-10">
            <div class="rounded-xl bg-error p-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-error-content">
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
              </svg>
            </div>
          </figure>
          <div class="card-body items-center text-center">
            <h2 class="card-title">Enterprise Security</h2>
            <p>SOC 2 compliant with encryption at rest and in transit, RBAC, and audit logs</p>
            <div class="card-actions">
              <button class="btn btn-error btn-sm">Learn More</button>
            </div>
          </div>
        </div>

        <div class="card bg-base-200 shadow-xl">
          <figure class="px-10 pt-10">
            <div class="rounded-xl bg-info p-4">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8 text-info-content">
                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375" />
              </svg>
            </div>
          </figure>
          <div class="card-body items-center text-center">
            <h2 class="card-title">100+ Integrations</h2>
            <p>Connect to databases, APIs, cloud storage, and enterprise applications</p>
            <div class="card-actions">
              <button class="btn btn-info btn-sm">Learn More</button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Solutions Section -->
  <section id="solutions" class="py-20 px-6 bg-base-200">
    <div class="container mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-4xl font-bold mb-4">Solutions for Every Industry</h2>
        <p class="text-xl text-base-content/70">Tailored data solutions that drive business outcomes</p>
      </div>

      <div class="carousel carousel-center max-w-full p-4 space-x-4">
        <div class="carousel-item">
          <div class="card w-96 bg-primary text-primary-content">
            <div class="card-body">
              <h2 class="card-title">Financial Services</h2>
              <p>Real-time fraud detection, regulatory reporting, and risk analytics</p>
              <div class="card-actions justify-end">
                <button class="btn">Learn More</button>
              </div>
            </div>
          </div>
        </div>
        <div class="carousel-item">
          <div class="card w-96 bg-secondary text-secondary-content">
            <div class="card-body">
              <h2 class="card-title">E-Commerce</h2>
              <p>Customer analytics, inventory optimization, and personalization engines</p>
              <div class="card-actions justify-end">
                <button class="btn">Learn More</button>
              </div>
            </div>
          </div>
        </div>
        <div class="carousel-item">
          <div class="card w-96 bg-accent text-accent-content">
            <div class="card-body">
              <h2 class="card-title">Healthcare</h2>
              <p>Patient data integration, clinical analytics, and compliance reporting</p>
              <div class="card-actions justify-end">
                <button class="btn">Learn More</button>
              </div>
            </div>
          </div>
        </div>
        <div class="carousel-item">
          <div class="card w-96 bg-info text-info-content">
            <div class="card-body">
              <h2 class="card-title">Manufacturing</h2>
              <p>IoT data processing, predictive maintenance, and supply chain optimization</p>
              <div class="card-actions justify-end">
                <button class="btn">Learn More</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-20 px-6 bg-base-100">
    <div class="container mx-auto">
      <h2 class="text-4xl font-bold text-center mb-12">What Our Customers Say</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card bg-base-200">
          <div class="card-body">
            <div class="rating mb-4">
              <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-1" class="mask mask-star-2 bg-orange-400" disabled checked />
            </div>
            <p class="text-base-content/80 mb-4">"DataFixPro has transformed how we handle data integration. The visual pipeline builder saved us months of development time."</p>
            <div class="flex items-center">
              <div class="avatar">
                <div class="w-12 rounded-full bg-primary">
                  <span class="flex items-center justify-center h-full text-primary-content font-bold">JD</span>
                </div>
              </div>
              <div class="ml-4">
                <p class="font-semibold">John Doe</p>
                <p class="text-sm text-base-content/60">CTO, TechCorp</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-base-200">
          <div class="card-body">
            <div class="rating mb-4">
              <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-2" class="mask mask-star-2 bg-orange-400" disabled checked />
            </div>
            <p class="text-base-content/80 mb-4">"The AI-powered transformations feature is a game-changer. It automatically suggests optimizations we never thought of."</p>
            <div class="flex items-center">
              <div class="avatar">
                <div class="w-12 rounded-full bg-secondary">
                  <span class="flex items-center justify-center h-full text-secondary-content font-bold">SM</span>
                </div>
              </div>
              <div class="ml-4">
                <p class="font-semibold">Sarah Miller</p>
                <p class="text-sm text-base-content/60">Data Lead, Analytics Inc</p>
              </div>
            </div>
          </div>
        </div>

        <div class="card bg-base-200">
          <div class="card-body">
            <div class="rating mb-4">
              <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" disabled />
              <input type="radio" name="rating-3" class="mask mask-star-2 bg-orange-400" disabled checked />
            </div>
            <p class="text-base-content/80 mb-4">"Outstanding support and rock-solid reliability. DataFixPro handles our mission-critical data pipelines flawlessly."</p>
            <div class="flex items-center">
              <div class="avatar">
                <div class="w-12 rounded-full bg-accent">
                  <span class="flex items-center justify-center h-full text-accent-content font-bold">MJ</span>
                </div>
              </div>
              <div class="ml-4">
                <p class="font-semibold">Michael Johnson</p>
                <p class="text-sm text-base-content/60">VP Engineering, DataFlow</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-6 bg-primary text-primary-content">
    <div class="container mx-auto text-center">
      <h2 class="text-4xl font-bold mb-6">Ready to Transform Your Data?</h2>
      <p class="text-xl mb-8 opacity-90">
        Join thousands of companies using DataFixPro to power their data infrastructure
      </p>
      <div class="flex flex-col md:flex-row gap-4 justify-center">
        <%= link_to "Start Your Free Trial", new_user_registration_path, class: "btn btn-accent btn-lg" %>
        <button class="btn btn-outline btn-lg text-primary-content border-primary-content hover:bg-primary-content hover:text-primary">
          Schedule a Demo
        </button>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer p-10 bg-neutral text-neutral-content">
    <div>
      <div class="avatar placeholder mb-4">
        <div class="bg-primary text-neutral-content rounded-lg w-12">
          <span class="text-2xl">DF</span>
        </div>
      </div>
      <p>DataFixPro<br/>Enterprise Analytics & Data Integration Platform</p>
    </div>
    <div>
      <span class="footer-title">Product</span>
      <a class="link link-hover">Features</a>
      <a class="link link-hover">Integrations</a>
      <a class="link link-hover">Pricing</a>
      <a class="link link-hover">Changelog</a>
    </div>
    <div>
      <span class="footer-title">Company</span>
      <a class="link link-hover">About us</a>
      <a class="link link-hover">Careers</a>
      <a class="link link-hover">Blog</a>
      <a class="link link-hover">Press</a>
    </div>
    <div>
      <span class="footer-title">Resources</span>
      <a class="link link-hover">Documentation</a>
      <a class="link link-hover">API Reference</a>
      <a class="link link-hover">Community</a>
      <a class="link link-hover">Support</a>
    </div>
    <div>
      <span class="footer-title">Legal</span>
      <a class="link link-hover">Privacy Policy</a>
      <a class="link link-hover">Terms of Service</a>
      <a class="link link-hover">Security</a>
      <a class="link link-hover">GDPR</a>
    </div>
  </footer>

  <div class="footer footer-center p-4 bg-neutral text-neutral-content border-t border-base-300">
    <aside>
      <p>© <%= Time.now.year %> DataFixPro. All rights reserved.</p>
    </aside>
  </div>
</div>